# BingX
BINGX_API_KEY=tu_api_key
BINGX_SECRET_KEY=tu_secret_key
# Telegram
TELEGRAM_TOKEN=123456:ABCdef
TELEGRAM_CHAT_ID=-100xxxxxxx
# Timeframe (investigación confirma 3m > 1m para esta estrategia)
TIMEFRAME=3m
KLINE_LIMIT=150
CANDLE_SLEEP=30
# Canal ZigZag
PIVOT_LEN=5
ATR_LEN=14
ATR_TRIGGER_MULT=0.5
SL_ATR_MULT=2.0
MIN_CANAL_ATR=1.5
COOLDOWN_BARS=10
# Filtros (OFF=máximas señales; activar gradualmente si hay demasiado ruido)
USE_EMA_FILTER=false
EMA_PERIOD=50
USE_RSI_FILTER=false
RSI_SHORT_MIN=60
RSI_LONG_MAX=40
USE_VOL_FILTER=false
VOL_MULT=1.3
# Trailing
TRAIL_PCT=50
# Riesgo
LEVERAGE=10
RISK_PCT=1.5
MAX_POSITIONS=5
MAX_DAILY_LOSS=5.0
# Scanner (investigación: óptimo 10-15 pares)
TOP_PAIRS=15
MIN_QUOTE_VOL=50000000
