# ════════════════════════════════════════════════
#  QF×JP Bot — Variables de entorno
#  Copia este archivo a .env y rellena los valores
#  NUNCA subas .env a GitHub
# ════════════════════════════════════════════════

# BingX API
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui

# Telegram
TELEGRAM_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Webhook secret (opcional, para pruebas manuales)
WEBHOOK_SECRET=qfjp_secret_2025

# ── Gestión de riesgo
TRADE_SIZE_USDT=10
MAX_OPEN_TRADES=2
SL_PCT=1.5
TP_PCT=3.0

# ── Nivel mínimo de señal para ejecutar orden
# HUNT_LONG/SHORT(1) < LONG/SHORT_FUEL(2) < LONG/SHORT_SUP(3) < LONG/SHORT_SUP_V3(4)
MIN_SIGNAL_LEVEL=LONG_FUEL

# ── Símbolos a escanear (separados por coma, formato BingX: BTC-USDT)
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT

# ── Timeframes
KLINE_INTERVAL=3m    # velas de señal (igual que el Pine)
HTF_INTERVAL=15m     # tendencia HTF
SCAN_INTERVAL=180    # segundos entre escaneos (180 = cada 3 min)

# Puerto (Railway lo asigna automáticamente)
PORT=8000
