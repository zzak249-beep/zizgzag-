# ── BingX ──────────────────────────────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# ── Telegram ───────────────────────────────────────────────────────────────────
# 1. Habla con @BotFather en Telegram → /newbot → copia el token
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2. Habla con @userinfobot en Telegram → copia tu ID numérico
TELEGRAM_CHAT_ID=987654321

# ── Modo operación ─────────────────────────────────────────────────────────────
# false = simulado (sin órdenes reales) | true = operar con dinero real
LIVE_TRADING=false
