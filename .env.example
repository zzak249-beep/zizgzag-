# ============================================================
# SNIPER BOT — Variables de Entorno
# Copia este archivo como .env y rellena tus credenciales
# ============================================================

# --- BINANCE ---
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_SECRET_KEY=tu_secret_key_aqui
TESTNET=false                         # true = paper trading, false = dinero real

# --- TELEGRAM ---
TELEGRAM_TOKEN=tu_token_bot_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# --- TRADING ---
SYMBOLS=BTCUSDT,ETHUSDT               # pares separados por coma
TIMEFRAME=15m                         # 1m,5m,15m,1h,4h
LEVERAGE=5                            # apalancamiento (1-20)
RISK_PER_TRADE=1.5                    # % del capital por operación

# --- MOTOR MARKOV ---
SLOPE_MIN=30.0
LOOKBACK_MARKOV=200
PROB_THRESHOLD=40.0

# --- ADX ADAPTATIVO ---
ADX_LEN=14
ADX_TREND=25
ADX_RANGE=20

# --- FILTROS ---
RVOL_MIN=1.5
POC_LOOKBACK=50
PIVOT_LEN=4

# --- TRIPLE BARRERA ---
ATR_MULT_TP=2.0
ATR_MULT_SL=1.2
MAX_BARS_HOLD=20

# --- KOTEGAWA ---
DIP_PCT=20.0
MA_LEN=25
RSI_LEN=14
RSI_OVERSOLD=24.0
BB_LEN=20
BB_MULT=2.0

# --- RIESGO GLOBAL ---
MAX_DAILY_LOSS_PCT=3.0                # DD máximo diario antes de pausar
MAX_OPEN_POSITIONS=2                  # posiciones simultáneas máximas
LOOP_INTERVAL=60                      # segundos entre ciclos
