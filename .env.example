# ════════════════════════════════════════════════
#  QF×JP Bot — Variables de entorno
#  Copia este archivo a .env y rellena los valores
#  NUNCA subas .env a GitHub
# ════════════════════════════════════════════════

# BingX API (obtener en: https://bingx.com/en-us/account/api/)
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui

# Telegram Bot (crear con @BotFather en Telegram)
TELEGRAM_TOKEN=tu_bot_token_aqui
# Chat ID: envía un mensaje al bot y visita
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Webhook secret (pon el mismo valor en TradingView alert header)
WEBHOOK_SECRET=qfjp_secret_2025

# Gestión de riesgo
TRADE_SIZE_USDT=10          # Dólares por trade
MAX_OPEN_TRADES=2           # Máximo de posiciones simultáneas
SL_PCT=1.5                  # % Stop Loss desde entrada
TP_PCT=3.0                  # % Take Profit desde entrada

# Señales permitidas (separadas por coma)
# Niveles: HUNT_LONG/SHORT(1) < LONG/SHORT_FUEL(2) < LONG/SHORT_SUP(3) < LONG/SHORT_SUP_V3(4)
ALLOWED_SIGNALS=LONG_SUP_V3,SHORT_SUP_V3,LONG_SUP,SHORT_SUP,LONG_FUEL,SHORT_FUEL,HUNT_LONG,HUNT_SHORT
MIN_SIGNAL_LEVEL=LONG_FUEL  # Nivel mínimo para ejecutar orden real

# Puerto (Railway lo asigna automáticamente)
PORT=8000
