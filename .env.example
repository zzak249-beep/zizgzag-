# ── Identity
BOT_NAME=ema9-vwap

# ── BingX credentials
BINGX_API_KEY=your_api_key
BINGX_SECRET_KEY=your_secret_key

# ── Trading
SYMBOL=BTC-USDT
TIMEFRAME=5m            # 1m 3m 5m 15m 30m 1h
DIRECTION=BOTH          # LONG | SHORT | BOTH
LEVERAGE=10

# ── Strategy (mirrors Pine Script defaults)
ATR_LENGTH=14
ATR_MULT=2.0
EMA_PERIOD=9
CANDLES=300

# ── Risk
RISK_PCT=1.0            # % equity risked per trade (sized via ATR SL)
MAX_NOTIONAL_USDT=200   # hard cap on position notional
MAX_DAILY_LOSS_PCT=3.0  # % equity → blocks new trades for the day

# ── Loop timing (seconds)
TRAILING_CHECK_SEC=20   # how often trail stop is evaluated
SIGNAL_CHECK_SEC=60     # how often crossover signal is checked

# ── Telegram
TELEGRAM_BOT_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id
