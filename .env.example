# ═══════════════════════════════════════════════
# SNIPER TURBO MARKOV — Variables Railway
# ═══════════════════════════════════════════════

# ── OBLIGATORIAS ────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321

# ── MODO ────────────────────────────────────────
# false = simulado | true = DINERO REAL
LIVE_TRADING=false

# ── PARES ───────────────────────────────────────
# Vacío = auto-descubrir TODOS los pares de BingX
CUSTOM_SYMBOLS=
# Limita cuántos pares escanear (0 = todos)
MAX_SYMBOLS=0

# ── TIMEFRAME ───────────────────────────────────
TIMEFRAME=1h
LOOP_SECONDS=60
SCAN_WORKERS=15

# ── MOTOR MARKOV ────────────────────────────────
MARKOV_LOOKBACK=200
SLOPE_MIN=25.0
MARKOV_BULL_MIN=30.0
MARKOV_BEAR_MIN=30.0

# ── FILTROS ─────────────────────────────────────
DENSITY_MULT=1.2
DENSITY_PERIOD=50
PIVOT_LEFT=4
PIVOT_RIGHT=4
MAX_SPREAD_PCT=0.15
SCAN_DEBUG=true

# ── SALIDA ──────────────────────────────────────
TRAIL_RISK_MULT=1.5
USE_TRAILING=true
USE_PARTIAL_TP=true
PARTIAL_R=1.5
PARTIAL_PCT=50
BE_MARGIN_BPS=10

# ── RISK ────────────────────────────────────────
RISK_PCT=1.5
LEVERAGE=3
MIN_ORDER_USDT=3.0
MAX_ORDER_USDT=50.0
MAX_MARGIN_PCT=20.0
MAX_OPEN_TRADES=6
MAX_SAME_DIR=3
MAX_DAILY_LOSS=5.0
MAX_CONSEC_LOSS=3
PAUSE_MINS=120
SIZE_REDUCE_PCT=50.0

# ── SESIÓN ──────────────────────────────────────
USE_SESSION=true
SESSION_OFF_START=0
SESSION_OFF_END=5
COOLDOWN_MINS=60

# ── BASE DE DATOS ───────────────────────────────
DB_PATH=/data/trades.db
