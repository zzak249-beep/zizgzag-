# ============================================================
#  ZigZag Breakout Bot — Variables de entorno
# ============================================================

# --- BingX API ---
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# --- Telegram ---
TELEGRAM_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# --- Símbolo a operar (ej: BTC-USDT, ETH-USDT, EUR-USD) ---
SYMBOL=BTC-USDT

# --- Configuración de la estrategia ---
LEVERAGE=10
TP_PIPS=45
SL_PIPS=30
TIMEFRAME=15m          # Solo 15m recomendado por la estrategia
CAPITAL_PER_TRADE=50   # USDT por operación (ajusta según tu capital)

# --- ZigZag config (igual que ZigZag++ en TradingView) ---
ZZ_DEPTH=12
ZZ_DEVIATION=5
ZZ_BACKSTEP=2
ZZ_LOOKBACK=100        # Cuántas velas analizar para calcular el ZigZag

# --- Horario de trading (UTC) ---
TRADE_START_HOUR=0     # 0 = todo el día
TRADE_END_HOUR=23

# --- Railway / entorno ---
ENV=production         # development | production
LOG_LEVEL=INFO
