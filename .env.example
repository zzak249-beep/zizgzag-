# ── BingX API ──────────────────────────────────────────────────────────────────
BINGX_API_KEY=your_api_key_here
BINGX_SECRET_KEY=your_secret_key_here

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Trade sizing ───────────────────────────────────────────────────────────────
TRADE_USDT=5
LEVERAGE=5

# ── Strategy ───────────────────────────────────────────────────────────────────
PERIOD=25          # Three Step period (Pine default = 25)
ATR_PERIOD=14
ATR_MULT=2.0       # SL distance = ATR * ATR_MULT  (= 1R)
RR=2.0             # TP = 1R * RR  (i.e. 2R target)
TIMEFRAME=1h       # 1m 5m 15m 30m 1h 4h 1d

# ── Symbols (comma-separated BingX perpetual format) ──────────────────────────
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT,DOGE-USDT,ADA-USDT,AVAX-USDT

# ── Position management ────────────────────────────────────────────────────────
MAX_POSITIONS=3
SCAN_INTERVAL=300  # seconds between scan cycles (300 = 5 min)

# ── Internal ───────────────────────────────────────────────────────────────────
PORT=8080
