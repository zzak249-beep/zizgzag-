# ════════════════════════════════════════════════════
#  Sniper Bot V50.6 — Environment Variables Template
#  Copy this to .env and fill in your real values.
#  On Railway, set these in the Variables dashboard.
# ════════════════════════════════════════════════════

# ─── BingX API (Perpetual Futures) ───────────────────
# Get from: https://bingx.com/en-us/account/api/
BINGX_API_KEY=your_bingx_api_key_here
BINGX_API_SECRET=your_bingx_api_secret_here

# ─── Telegram ─────────────────────────────────────────
# 1. Create bot via @BotFather → get token
# 2. Get chat ID: message @userinfobot or check getUpdates
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=-1001234567890

# ─── Capital & Risk ───────────────────────────────────
INITIAL_CAPITAL=1000          # USDT — used for position sizing reference
RISK_PER_TRADE_PCT=2.0        # % of capital risked per trade
MAX_OPEN_POSITIONS=3          # Max concurrent positions
LEVERAGE=5                    # Exchange leverage (5x recommended)
USE_KELLY=true                # Use Kelly Criterion for dynamic sizing

# ─── Trading Pairs ────────────────────────────────────
SYMBOLS=GWEIUSDT,BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,AVAXUSDT,LINKUSDT,ARBUSDT

# ─── Timeframes ──────────────────────────────────────
PRIMARY_TF=2h                 # Signal timeframe (matches Pine Script)
CONFIRM_TF=4h                 # Multi-TF confluence filter

# ─── Strategy Tuning ─────────────────────────────────
ATR_ENTRY_MULT=2.5            # Breakout level multiplier
RVOL_THRESHOLD=1.5            # Minimum relative volume
SLOPE_THRESHOLD=40.0          # Minimum EMA7 slope
ADX_MIN=22.0                  # Minimum ADX for trend strength

# ─── Session Filter ──────────────────────────────────
SESSION_FILTER=true           # Skip 0-5 UTC (dead liquidity)

# ─── Scanning ────────────────────────────────────────
SCAN_INTERVAL_SECONDS=120     # Seconds between full scans

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
