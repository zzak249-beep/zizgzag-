# ═══════════════════════════════════════
# Maki Bot v2 — Variables de entorno
# NUNCA subas este archivo a GitHub
# ═══════════════════════════════════════

# ── BingX ────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui

# ── Telegram ─────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=tu_chat_id

# ── Trading ───────────────────────────
TRADE_AMOUNT_USDT=10       # USDT por trade (margen)
LEVERAGE=10                # Apalancamiento fijo
MAX_OPEN_TRADES=5          # Máximo posiciones simultáneas

# ── Escaneo ───────────────────────────
SCAN_INTERVAL_SECONDS=60   # Segundos entre escaneos
SCAN_BATCH_SIZE=10         # Pares en paralelo (no subir de 15)
COOLDOWN_SECONDS=300       # Espera tras cerrar un par
MIN_VOLUME_USDT=1000000    # Volumen mínimo 24h (filtra basura)
