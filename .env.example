# ── BingX ─────────────────────────────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321

# ── Modo ──────────────────────────────────────────────────────────────────────
# false = simulado (30 días mínimo antes de live) | true = dinero real
LIVE_TRADING=false

# ── Pares — 8 ÓPTIMOS para Markov (no cambiar sin razón) ─────────────────────
CUSTOM_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT,ADA-USDT,AVAX-USDT,DOGE-USDT

# ── Timeframe ─────────────────────────────────────────────────────────────────
TIMEFRAME=15m

# ── Motor Markov ──────────────────────────────────────────────────────────────
MARKOV_LOOKBACK=200
SLOPE_MIN=30.0
MARKOV_BULL_MIN=40.0
MARKOV_BEAR_MIN=40.0

# ── Filtros entrada ───────────────────────────────────────────────────────────
DENSITY_MULT=2.0
DENSITY_PERIOD=50
PIVOT_LEFT=4
PIVOT_RIGHT=4

# ── Risk ──────────────────────────────────────────────────────────────────────
LEVERAGE=3
RISK_PCT=1.5
MAX_OPEN_TRADES=4
MAX_DAILY_LOSS=5.0
MAX_CONSEC_LOSS=3
PAUSE_MINS=120

# ── Salida ────────────────────────────────────────────────────────────────────
TRAIL_RISK_MULT=1.5
USE_PARTIAL_TP=true
PARTIAL_R=1.5
PARTIAL_PCT=50

# ── Session ───────────────────────────────────────────────────────────────────
USE_SESSION=true
SESSION_OFF_START=0
SESSION_OFF_END=5
