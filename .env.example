# ─── BingX API ───────────────────────────────────────────────
BINGX_API_KEY=your_bingx_api_key_here
BINGX_API_SECRET=your_bingx_api_secret_here

# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Configuración del bot ───────────────────────────────────
# Par a operar (ej: BTC/USDT, ETH/USDT, SOL/USDT)
SYMBOL=BTC/USDT

# Timeframe (5m, 15m, 1h, etc.)
TIMEFRAME=5m

# Capital por operación en % del balance (1–100)
RISK_PCT=2.0

# Apalancamiento (1 = sin apalancamiento, max recomendado: 5)
LEVERAGE=1

# Modo: live | paper
MODE=paper
