# ─── BingX API ───────────────────────────────────────────────
BINGX_API_KEY=your_bingx_api_key_here
BINGX_API_SECRET=your_bingx_api_secret_here

# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Par y temporalidad ──────────────────────────────────────
SYMBOL=BTC/USDT
TIMEFRAME=5m

# ─── Riesgo ──────────────────────────────────────────────────
RISK_PCT=2.0          # % del balance por operación
LEVERAGE=3            # apalancamiento (1 = sin apalancamiento)
MAX_TRADES_DAY=6      # máximo operaciones por día

# ─── Modo ────────────────────────────────────────────────────
# paper  → simula sin dinero real
# live   → opera con dinero real en BingX
MODE=paper

# ─── Funding rate ────────────────────────────────────────────
FUNDING_THRESHOLD=0.01   # % mínimo para considerar funding extremo
FUNDING_AVOID=true        # true = evita operar contra funding extremo

# ─── Liquidation map ─────────────────────────────────────────
LIQ_LOOKBACK=100          # velas para calcular zonas de liquidación
LIQ_MULTIPLIER=1.5        # ATR mult para zona de liquidación
