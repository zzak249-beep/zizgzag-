# ─── BINGX ───────────────────────────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui
BINGX_BASE_URL=https://open-api.bingx.com

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ─── SÍMBOLOS ─────────────────────────────────────────────────────────────────
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT

# ─── TRADING ──────────────────────────────────────────────────────────────────
LEVERAGE=5
RISK_PER_TRADE=0.01
MAX_OPEN_TRADES=3

# ─── SCORE UMBRALES QF×JP v3.4 ───────────────────────────────────────────────
SCORE_STD=55
SCORE_FUEL=68
SCORE_SUP=80
HTF_MIN=2

# ─── GESTIÓN DE RIESGO ────────────────────────────────────────────────────────
DAILY_LOSS=0.05
MAX_DRAWDOWN=0.10
CB_ON=true
CB_BARS=10
CB_MULT=3.0
PTP_ON=true
PTP_PCT=0.25

# ─── KELLY ────────────────────────────────────────────────────────────────────
KELLY=true
KELLY_FRAC=0.25
KELLY_WR=0.55
KELLY_RR=1.8

# ─── CANDLES Y TIMEFRAMES ─────────────────────────────────────────────────────
CANDLE_TF=3m
CANDLE_LIMIT=300
HTF_15M=15m
HTF_1H=1h
HTF_W=1w
HTF_1M=1m

# ─── INDICADORES ──────────────────────────────────────────────────────────────
ATR_LEN=10
ATR_SL=1.0
ATR_TP1=1.5
ATR_TP2=3.0
ATR_PTP=0.5
ADX_LEN=14
ADX_TREND=25
ADX_LAT=20
CVD_LEN=20
CVD_ROLL=100
SQ_LEN=20
VP_LEN=100
VP_BINS=24
OB_BARS=50
OB_IMP=1.5
FVG_MIN=0.3
FVG_BARS=40
FVG_MAX=5

# ─── FILTROS ──────────────────────────────────────────────────────────────────
VOL_FILTER=true
VOL_THR=0.70
EXEC_BPT=0.18
OVL_BOOST=3
SES_ASIA=false

# ─── MARKET MECHANICS ─────────────────────────────────────────────────────────
ENABLE_SESSION_FILTER=true
ENABLE_FUNDING_FILTER=true
ENABLE_OI_FILTER=true
ENABLE_LIQ_MAP=true
SESSION_HARD_BLOCK=true

# ─── SISTEMA ──────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO
CYCLE_MINUTES=3
